# --- AI providers ---
ANTHROPIC_API_KEY=sk-ant-...   # required only when LLM_PROVIDER=anthropic, or per-call opt-in
OPENAI_API_KEY=sk-...          # shared by text generation (LLMProvider) and GPT Image 2 -- same
                                # OpenAI account, not the isolated OPENAI_API_KEY_POC used by /poc
LLM_PROVIDER=openai            # openai | anthropic -- fleet-wide default; per-call override via
                                # LLMProvider(provider=...) always available regardless of this
LLM_MODEL_CHEAP=gpt-5.6-luna
LLM_MODEL_STRONG=gpt-5.5
LLM_MODEL_CHEAP_ANTHROPIC=claude-haiku-4-5-20251001   # only read when provider="anthropic"
LLM_MODEL_STRONG_ANTHROPIC=claude-sonnet-5             # only read when provider="anthropic"
IMAGE_MODEL=gpt-image-2

# --- Supabase ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_DB_URL=postgresql://...

# --- Cost / quality flags ---
IMAGE_QUALITY=low             # medium | low  — low chosen after comparing duotoned output: visually
                              # indistinguishable, ~2-4x faster, ~8x cheaper
IMAGE_SIZE=1024x1536          # portrait
ENABLE_CRITIQUE=true          # draft->critique->refine on every post
ENABLE_PROMPT_CACHE=true

# --- CORS ---
FRONTEND_ORIGIN=https://your-app.vercel.app
